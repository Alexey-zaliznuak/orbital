{
    "swagger": "2.0",
    "info": {
        "contact": {}
    },
    "paths": {
        "/api/v1/config": {
            "get": {
                "description": "Возвращает текущую конфигурацию gateway сервиса",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Config"
                ],
                "summary": "Получить конфигурацию gateway",
                "responses": {
                    "200": {
                        "description": "Конфигурация gateway",
                        "schema": {
                            "$ref": "#/definitions/gateway.GatewayConfig"
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка сервера",
                        "schema": {
                            "$ref": "#/definitions/gatewayapi.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/health": {
            "get": {
                "description": "Возвращает статус работоспособности gateway",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Health"
                ],
                "summary": "Проверка здоровья сервиса",
                "responses": {
                    "200": {
                        "description": "Сервис работает",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/message": {
            "post": {
                "description": "Принимает сообщение для последующей доставки через storage ноды",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Messages"
                ],
                "summary": "Отправить сообщение",
                "parameters": [
                    {
                        "description": "Данные сообщения",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/gatewayapi.NewMessageRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Сообщение успешно создано",
                        "schema": {
                            "$ref": "#/definitions/gatewayapi.NewMessageResponse"
                        }
                    },
                    "400": {
                        "description": "Некорректный запрос",
                        "schema": {
                            "$ref": "#/definitions/gatewayapi.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка сервера",
                        "schema": {
                            "$ref": "#/definitions/gatewayapi.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "gateway.GatewayConfig": {
            "type": "object",
            "properties": {
                "cluster_address": {
                    "type": "string"
                },
                "grpc_addr": {
                    "type": "string"
                },
                "http_addr": {
                    "type": "string"
                },
                "log_level": {
                    "type": "string"
                }
            }
        },
        "gatewayapi.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string",
                    "example": "invalid request body"
                }
            }
        },
        "gatewayapi.NewMessageRequest": {
            "type": "object",
            "required": [
                "payload",
                "routing_key"
            ],
            "properties": {
                "metadata": {
                    "description": "Metadata содержит дополнительные метаданные сообщения.",
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    },
                    "example": {
                        "priority": "high",
                        "source": "api"
                    }
                },
                "payload": {
                    "description": "Payload содержит полезную нагрузку сообщения (base64).",
                    "type": "array",
                    "items": {
                        "type": "integer"
                    }
                },
                "routing_key": {
                    "description": "RoutingKey определяет в какие пушеры попадёт сообщение.",
                    "type": "string",
                    "example": "notifications.email"
                },
                "scheduled_at": {
                    "description": "ScheduledAt — время, когда сообщение должно быть доставлено.\nЕсли не задано (zero value), сообщение доставляется немедленно.",
                    "type": "string",
                    "example": "2024-01-15T10:30:00Z"
                }
            }
        },
        "gatewayapi.NewMessageResponse": {
            "type": "object",
            "properties": {
                "id": {
                    "description": "ID уникальный идентификатор созданного сообщения.",
                    "type": "string",
                    "example": "msg_01HQ3K5X7Y8Z9ABC"
                },
                "metadata": {
                    "description": "Metadata содержит дополнительные метаданные сообщения.",
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    },
                    "example": {
                        "priority": "high",
                        "source": "api"
                    }
                },
                "payload": {
                    "description": "Payload содержит полезную нагрузку сообщения (base64).",
                    "type": "array",
                    "items": {
                        "type": "integer"
                    }
                },
                "routing_key": {
                    "description": "RoutingKey определяет в какие пушеры попадёт сообщение.",
                    "type": "string",
                    "example": "notifications.email"
                },
                "scheduled_at": {
                    "description": "ScheduledAt — время, когда сообщение должно быть доставлено.",
                    "type": "string",
                    "example": "2024-01-15T10:30:00Z"
                }
            }
        }
    }
}